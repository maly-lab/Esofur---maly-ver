#!/usr/bin/env python3

from esofur_engine import EsoFurCompiler
import sys
import os

compiler = EsoFurCompiler()

# ---------------- RUN FILE MODE ----------------
def run_file(path):
    compiler.script_dir = os.path.dirname(os.path.abspath(path))
    with open(path, "r") as f:
        code = f.read()
    compiler.compile(code)

# ---------------- REPL MODE ----------------
def repl():
    print("EsoFur REPL v3 (clean mode)")
    print("Type 'exit' to quit")

    while True:
        try:
            # ALWAYS show prompt FIRST
            line = input(">>> ").strip()

            if line == "exit":
                break

            if not line:
                continue

            # execute AFTER input
            result = compiler.execute_line(line)

            # only print if engine returns something
            if result is not None:
                print(result)

        except KeyboardInterrupt:
            print("\nExiting REPL")
            break
# ---------------- ENTRY POINT ----------------
if len(sys.argv) == 1:
    repl()

elif sys.argv[1] == "repl":
    repl()

elif sys.argv[1] == "run":
    if len(sys.argv) < 3:
        print("Usage: esofur run <file.EsoFur>")
        sys.exit(1)

    run_file(sys.argv[2])

else:
    # shorthand: esofur file.EsoFur
    run_file(sys.argv[1])
